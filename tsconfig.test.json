{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "types": ["node", "vitest/globals", "vitest/jsdom", "vitest/browser", "@testing-library/jest-dom"]
  },
  "include": [
    "src/**/*.spec.ts",
    "src/**/*.spec.tsx",
    "scripts/**/*.spec.ts",
    "scripts/**/*.spec.tsx",
    "tests/**/*.ts",
    "tests/**/*.tsx",
    "vitest.setup.ts"
  ],
  "exclude": ["dist", "build", "coverage", "node_modules"]
}
